{
  "schemaVersion": 1,
  "id": "somefrills",
  "version": "${version}",
  "name": "SomeFrills",
  "description": "This Mod does stuff",
  "authors": [
    "NaorVaninu"
  ],
  "contributors" : [
    "ItsRealHim"
  ],
  "contact": {
    "sources": "https://github.com/AverageUser125/SomeFrills",
    "issues": "https://github.com/AverageUser125/SomeFrills/issues"
  },
  "license": "GPLv3",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.somefrills.Main"
    ],
    "modmenu": [
      "com.somefrills.config.ModMenuIntegration"
    ]
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.github_releases" : "https://github.com/AverageUser125/SomeFrills/releases"
      }
    },
    "mc-publish": {
      "loaders": ["fabric"]
    }
  },
  "mixins": [
    "somefrills.mixins.json"
  ],
  "accessWidener": "somefrills.accesswidener",
  "depends": {
    "fabricloader": ">=0.16.14",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*",
    "skyhanni": ">=7.11.0"
  }
}